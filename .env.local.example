# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key   # solo servidor, NUNCA exponer

# ── Meta WhatsApp Cloud API ──────────────────────────────
# Token que vos elegís y cargás igual en Meta Developer Console (webhook verify)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=elegi_un_token_secreto

# App Secret de tu app de Meta (para validar la firma X-Hub-Signature-256)
META_APP_SECRET=

# Fallback si un número no está cargado en la tabla whatsapp_accounts
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v23.0

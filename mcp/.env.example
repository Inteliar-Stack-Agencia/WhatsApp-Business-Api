# ── Meta Graph API (WhatsApp Cloud API + Marketing API) ──────────────
META_ACCESS_TOKEN=
META_API_VERSION=v25.0

# Defaults opcionales: se usan si una tool no recibe waba_id / ad_account_id
# explícito. Útil para el cliente principal; para otros clientes de la
# agencia, pasá el id correspondiente en cada llamada.
META_WABA_ID=
META_AD_ACCOUNT_ID=

# ── Supabase (inbox de Inteliar) ──────────────────────────────────────
# Mismo proyecto que usa la app Next.js (Riweb.app) — service role,
# porque este MCP corre server-side y necesita saltear RLS.
SUPABASE_URL=https://xeqbapfjosgchkhqwzsh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Transporte ─────────────────────────────────────────────────────────
# "stdio" (default, para Claude Code/Desktop local) o "http" (servidor remoto)
TRANSPORT=stdio
PORT=3100
